# Яндекс API для команды /yandex
# Полная инструкция: docs/YANDEX_ENV.md
#
# 1. cp .env.yandex.example .env.local
# 2. Заполни значения (файл .env.local не коммитить!)
# 3. Один OAuth-токен можно вставить во все *_OAUTH_TOKEN, если в приложении выданы все права

# --- OAuth (получить: docs/YANDEX_ENV.md §2–3) ---
# Ссылка: https://oauth.yandex.ru/authorize?response_type=token&client_id=<CLIENT_ID>

YANDEX_WEBMASTER_OAUTH_TOKEN=
YANDEX_METRIKA_OAUTH_TOKEN=
YANDEX_DIRECT_OAUTH_TOKEN=

# --- ID объектов (не секреты, но лучше в .env.local) ---

# Вебмастер: host_id сайта (кабинет или API)
YANDEX_WEBMASTER_HOST_ID=

# Метрика: Настройки счётчика → «Номер счётчика»
YANDEX_METRIKA_COUNTER_ID=

# Бизнес: число из URL yandex.ru/maps/org/.../1234567890/
# Отдельного API-токена для карточки нет — см. docs/YANDEX_ENV.md §6
YANDEX_BUSINESS_ORG_ID=
YANDEX_BUSINESS_CARD_URL=
