# Скопируй в .env.local (не коммитить!)
# Полная инструкция: SETUP.md в корне этого репозитория
#
# cp .env.yandex.example .env.local
#
# Токен: https://oauth.yandex.ru/authorize?response_type=token&client_id=<CLIENT_ID>
# Client ID — после создания приложения на oauth.yandex.ru/client/new
# Один токен можно вставить во все три поля ниже

YANDEX_WEBMASTER_OAUTH_TOKEN=
YANDEX_METRIKA_OAUTH_TOKEN=
YANDEX_DIRECT_OAUTH_TOKEN=

# webmaster.yandex.ru — host_id сайта
YANDEX_WEBMASTER_HOST_ID=

# metrika.yandex.ru — Настройки → номер счётчика
YANDEX_METRIKA_COUNTER_ID=

# yandex.ru/maps/org/.../1234567890/ — число в конце URL, токен не нужен
YANDEX_BUSINESS_ORG_ID=
YANDEX_BUSINESS_CARD_URL=
