---
---

<section id="contact" class="section-padding bg-surface reveal" aria-labelledby="contact-title">
  <div class="container-site">
    <div class="mx-auto max-w-xl rounded-sm border border-border bg-surface-elevated p-8">
      <h2 id="contact-title" class="section-title text-center">Остались вопросы?</h2>
      <p class="section-subtitle text-center">Оставьте контакты — перезвоним и расскажем об абонементах.</p>

      <form data-validate-form novalidate>
        <div class="mb-4">
          <label class="form-label" for="contact-name">Ваше имя</label>
          <input
            class="form-input"
            type="text"
            id="contact-name"
            name="name"
            autocomplete="name"
            placeholder="Иван"
            required
            minlength="2"
            aria-describedby="contact-name-error"
          />
          <p class="form-error" id="contact-name-error" data-error="name" hidden></p>
        </div>

        <div class="mb-6">
          <label class="form-label" for="contact-phone">Телефон</label>
          <input
            class="form-input"
            type="tel"
            id="contact-phone"
            name="phone"
            data-phone-mask
            autocomplete="tel"
            placeholder="+7 (___) ___-__-__"
            required
            aria-describedby="contact-phone-error"
          />
          <p class="form-error" id="contact-phone-error" data-error="phone" hidden></p>
        </div>

        <button type="submit" class="btn-primary w-full">Отправить</button>
      </form>

      <div data-form-success hidden class="py-8 text-center" aria-live="polite">
        <p class="text-lg font-semibold text-accent">Спасибо! Мы свяжемся с вами в ближайшее время.</p>
      </div>
    </div>
  </div>
</section>
