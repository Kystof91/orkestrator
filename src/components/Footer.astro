---
import { site } from '../data/site';
---

<footer class="border-t border-border bg-surface section-padding">
  <div class="container-site">
    <div class="reveal grid gap-10 md:grid-cols-2 lg:grid-cols-3">
      <div>
        <p class="font-display text-2xl font-bold uppercase text-foreground">{site.name}</p>
        <p class="mt-2 text-muted">{site.tagline}</p>
      </div>

      <div>
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted">Контакты</h2>
        <ul class="space-y-2 text-foreground">
          <li>
            <a href={site.phoneHref} class="hover:text-accent transition-colors">{site.phone}</a>
          </li>
          <li>
            <address class="not-italic">{site.address}</address>
          </li>
        </ul>
      </div>

      <div>
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted">Реквизиты</h2>
        <ul class="space-y-1 text-sm text-muted">
          <li>ИНН: {site.inn}</li>
          <li>ОГРНИП: {site.ogrnip}</li>
        </ul>
        <button type="button" class="btn-primary mt-6" data-modal-open="modal-callback">
          Обратный звонок
        </button>
      </div>
    </div>

    <div class="mt-12 border-t border-border pt-8 text-center text-sm text-muted">
      <p>{site.copyright}</p>
    </div>
  </div>
</footer>
