---
import { Image } from 'astro:assets';
import Carousel from './Carousel.astro';
import { galleryImages } from '../data/site';

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/images/*.{jpg,jpeg,png,webp}', {
  eager: true,
});

function getImage(filename: string) {
  return images[`../assets/images/${filename}`]?.default;
}
---

<section id="gallery" class="section-padding reveal" aria-labelledby="gallery-title">
  <div class="container-site">
    <h2 id="gallery-title" class="section-title">Галерея</h2>
    <p class="section-subtitle">Загляните в наш клуб — современные залы и комфортная атмосфера.</p>

    <Carousel id="gallery-carousel" label="Галерея клуба" autoplay={5000}>
      {
        galleryImages.map((filename, index) => {
          const img = getImage(filename);
          return (
            <div class="carousel__slide px-1" role="group" aria-roledescription="slide" aria-label={`${index + 1} из ${galleryImages.length}`}>
              {img && (
                <Image
                  src={img}
                  alt={`Фото зала ${index + 1}`}
                  class="mx-auto aspect-[16/10] max-h-[480px] w-full rounded-sm object-cover"
                  widths={[600, 900, 1200]}
                  sizes="(max-width: 768px) 100vw, 900px"
                  loading="lazy"
                />
              )}
            </div>
          );
        })
      }
      <Fragment slot="dots">
        {galleryImages.map((_, index) => (
          <button
            type="button"
            class:list={['carousel__dot', index === 0 && 'is-active']}
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            aria-label={`Слайд ${index + 1}`}
          />
        ))}
      </Fragment>
    </Carousel>
  </div>
</section>
