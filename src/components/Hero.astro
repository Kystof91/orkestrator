---
import { Image } from 'astro:assets';
import { heroSlides, site } from '../data/site';

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/images/*.{jpg,jpeg,png,webp}', {
  eager: true,
});

function getImage(filename: string) {
  const key = `../assets/images/${filename}`;
  return images[key]?.default;
}
---

<section class="hero-slider" data-hero-slider aria-label="Главный слайдер">
  {
    heroSlides.map((slide, index) => {
      const img = getImage(slide.image);
      return (
        <article
          class:list={['hero-slide', index === 0 && 'is-active']}
          aria-hidden={index === 0 ? 'false' : 'true'}
        >
          {img && (
            <div class="absolute inset-0 overflow-hidden">
              <Image
                src={img}
                alt=""
                class="hero-slide__bg size-full object-cover"
                widths={[800, 1200, 1600]}
                sizes="100vw"
                loading={index === 0 ? 'eager' : 'lazy'}
              />
              <div class="absolute inset-0 bg-gradient-to-r from-background/95 via-background/70 to-background/30" />
            </div>
          )}
          <div class="container-site relative z-10 flex min-h-[85vh] flex-col justify-center py-24">
            <div class="hero-content max-w-2xl">
              <p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-accent">{site.tagline}</p>
              <h1 class="mb-4 text-4xl uppercase leading-tight md:text-5xl lg:text-6xl">{slide.title}</h1>
              <p class="mb-8 text-lg text-muted md:text-xl">{slide.subtitle}</p>
              <button type="button" class="btn-primary" data-modal-open="modal-application">
                Оставить заявку
              </button>
            </div>
          </div>
        </article>
      );
    })
  }

  <div class="absolute bottom-8 left-1/2 z-20 flex -translate-x-1/2 gap-2" role="tablist" aria-label="Слайды hero">
    {
      heroSlides.map((_, index) => (
        <button
          type="button"
          class:list={['carousel__dot', index === 0 && 'is-active']}
          data-hero-dot
          role="tab"
          aria-selected={index === 0 ? 'true' : 'false'}
          aria-label={`Слайд ${index + 1}`}
        />
      ))
    }
  </div>
</section>
