---
interface Props {
  id: string;
  title: string;
  showProduct?: boolean;
}

const { id, title, showProduct = false } = Astro.props;
---

<div
  id={id}
  class="modal-backdrop"
  hidden
  role="dialog"
  aria-modal="true"
  aria-labelledby={`${id}-title`}
  aria-hidden="true"
>
  <div class="modal-panel" role="document">
    <div class="mb-6 flex items-center justify-between">
      <h2 id={`${id}-title`} class="text-xl font-bold uppercase">{title}</h2>
      <button
        type="button"
        class="flex size-9 items-center justify-center rounded-sm border border-border text-muted hover:text-foreground"
        data-modal-close
        aria-label="Закрыть"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <form data-validate-form novalidate>
      {showProduct && <input type="hidden" name="product" value="" />}

      <div class="mb-4">
        <label class="form-label" for={`${id}-name`}>Ваше имя</label>
        <input
          class="form-input"
          type="text"
          id={`${id}-name`}
          name="name"
          autocomplete="name"
          placeholder="Иван"
          required
          minlength="2"
          aria-describedby={`${id}-name-error`}
        />
        <p class="form-error" id={`${id}-name-error`} data-error="name" hidden></p>
      </div>

      <div class="mb-6">
        <label class="form-label" for={`${id}-phone`}>Телефон</label>
        <input
          class="form-input"
          type="tel"
          id={`${id}-phone`}
          name="phone"
          data-phone-mask
          autocomplete="tel"
          placeholder="+7 (___) ___-__-__"
          required
          aria-describedby={`${id}-phone-error`}
        />
        <p class="form-error" id={`${id}-phone-error`} data-error="phone" hidden></p>
      </div>

      <button type="submit" class="btn-primary w-full">Отправить</button>
    </form>

    <div data-form-success hidden class="py-8 text-center" aria-live="polite">
      <p class="text-lg font-semibold text-accent">Спасибо! Мы свяжемся с вами в ближайшее время.</p>
    </div>
  </div>
</div>
