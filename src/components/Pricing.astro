---
import Carousel from './Carousel.astro';
import { tariffs } from '../data/site';

function formatPrice(value: number): string {
  return new Intl.NumberFormat('ru-RU').format(value);
}
---

<section id="pricing" class="section-padding bg-surface reveal" aria-labelledby="pricing-title">
  <div class="container-site">
    <h2 id="pricing-title" class="section-title">Тарифы</h2>
    <p class="section-subtitle">Выберите абонемент и начните тренироваться уже сегодня. Скидка 30% на все тарифы.</p>

    <div class="hidden gap-6 md:grid md:grid-cols-3">
      {
        tariffs.map((t) => (
          <article
            class:list={[
              'pricing-card relative flex flex-col rounded-sm border border-border bg-surface-elevated p-6',
              'popular' in t && t.popular && 'border-accent ring-1 ring-accent/30',
            ]}
          >
            {'popular' in t && t.popular && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-sm bg-accent px-3 py-1 text-xs font-bold uppercase text-white">
                Популярный
              </span>
            )}
            <span class="mb-2 inline-flex w-fit rounded-sm bg-accent-muted/20 px-2 py-1 text-xs font-bold text-accent">
              {t.discount}
            </span>
            <h3 class="text-xl font-bold uppercase">{t.title}</h3>
            <div class="my-4">
              <p class="text-sm text-muted line-through">{formatPrice(t.oldPrice)} ₽</p>
              <p class="text-4xl font-bold text-accent">
                {formatPrice(t.price)} <span class="text-lg text-muted">₽</span>
              </p>
            </div>
            <ul class="mb-6 flex-1 space-y-2 text-sm text-muted">
              {t.features.map((f) => (
                <li class="flex items-center gap-2">
                  <svg class="size-4 shrink-0 text-accent" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <button type="button" class="btn-primary w-full" data-modal-open="modal-order" data-product={t.title}>
              Заказать
            </button>
          </article>
        ))
      }
    </div>

    <div class="md:hidden">
      <Carousel id="pricing-carousel" label="Тарифы" autoplay={6000}>
        {
          tariffs.map((t, index) => (
            <div class="carousel__slide px-2" role="group" aria-roledescription="slide" aria-label={`${index + 1} из ${tariffs.length}`}>
              <article
                class:list={[
                  'pricing-card relative flex flex-col rounded-sm border border-border bg-surface-elevated p-6',
                  'popular' in t && t.popular && 'border-accent ring-1 ring-accent/30',
                ]}
              >
                {'popular' in t && t.popular && (
                  <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-sm bg-accent px-3 py-1 text-xs font-bold uppercase text-white">
                    Популярный
                  </span>
                )}
                <span class="mb-2 inline-flex w-fit rounded-sm bg-accent-muted/20 px-2 py-1 text-xs font-bold text-accent">
                  {t.discount}
                </span>
                <h3 class="text-xl font-bold uppercase">{t.title}</h3>
                <div class="my-4">
                  <p class="text-sm text-muted line-through">{formatPrice(t.oldPrice)} ₽</p>
                  <p class="text-4xl font-bold text-accent">
                    {formatPrice(t.price)} <span class="text-lg text-muted">₽</span>
                  </p>
                </div>
                <ul class="mb-6 flex-1 space-y-2 text-sm text-muted">
                  {t.features.map((f) => (
                    <li class="flex items-center gap-2">
                      <svg class="size-4 shrink-0 text-accent" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                      {f}
                    </li>
                  ))}
                </ul>
                <button type="button" class="btn-primary w-full" data-modal-open="modal-order" data-product={t.title}>
                  Заказать
                </button>
              </article>
            </div>
          ))
        }
        <Fragment slot="dots">
          {tariffs.map((_, index) => (
            <button
              type="button"
              class:list={['carousel__dot', index === 0 && 'is-active']}
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              aria-label={`Слайд ${index + 1}`}
            />
          ))}
        </Fragment>
      </Carousel>
    </div>
  </div>
</section>
