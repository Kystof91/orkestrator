---
import { Image } from 'astro:assets';
import Carousel from './Carousel.astro';
import { reviews } from '../data/site';

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/images/*.{jpg,jpeg,png,webp}', {
  eager: true,
});

function getImage(filename: string) {
  return images[`../assets/images/${filename}`]?.default;
}
---

<section id="reviews" class="section-padding reveal" aria-labelledby="reviews-title">
  <div class="container-site">
    <h2 id="reviews-title" class="section-title">Отзывы</h2>
    <p class="section-subtitle">Что говорят наши клиенты о тренировках в клубе СЭР.</p>

    <Carousel id="reviews-carousel" label="Отзывы клиентов" autoplay={7000}>
      {
        reviews.map((review, index) => {
          const img = getImage(review.image);
          return (
            <div class="carousel__slide px-2" role="group" aria-roledescription="slide" aria-label={`${index + 1} из ${reviews.length}`}>
              <article class="mx-auto max-w-2xl rounded-sm border border-border bg-surface p-8">
                <div class="mb-6 flex items-center gap-4">
                  {img && (
                    <Image
                      src={img}
                      alt=""
                      class="size-16 rounded-full object-cover"
                      width={64}
                      height={64}
                      loading="lazy"
                    />
                  )}
                  <div>
                    <p class="font-bold">{review.name}</p>
                    <p class="text-sm text-muted">{review.company}</p>
                  </div>
                </div>
                <blockquote class="text-lg leading-relaxed text-foreground/90">
                  <p>«{review.text}»</p>
                </blockquote>
              </article>
            </div>
          );
        })
      }
      <Fragment slot="dots">
        {reviews.map((_, index) => (
          <button
            type="button"
            class:list={['carousel__dot', index === 0 && 'is-active']}
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            aria-label={`Слайд ${index + 1}`}
          />
        ))}
      </Fragment>
    </Carousel>
  </div>
</section>
