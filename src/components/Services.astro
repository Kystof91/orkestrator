---
import { Image } from 'astro:assets';
import Carousel from './Carousel.astro';
import { services } from '../data/site';

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/images/*.{jpg,jpeg,png,webp}', {
  eager: true,
});

function getImage(filename: string) {
  return images[`../assets/images/${filename}`]?.default;
}
---

<section id="services" class="section-padding reveal" aria-labelledby="services-title">
  <div class="container-site">
    <h2 id="services-title" class="section-title">Услуги и зоны</h2>
    <p class="section-subtitle">Всё для эффективных тренировок — от силовых зон до фитнес-бара.</p>

    <Carousel id="services-carousel" label="Услуги и зоны" autoplay={5500}>
      {
        services.map((service, index) => {
          const img = getImage(service.image);
          return (
            <div class="carousel__slide px-2" role="group" aria-roledescription="slide" aria-label={`${index + 1} из ${services.length}`}>
              <article class="mx-auto max-w-md overflow-hidden rounded-sm border border-border bg-surface">
                {img && (
                  <Image
                    src={img}
                    alt={service.title}
                    class="aspect-[4/3] w-full object-cover"
                    widths={[400, 600, 800]}
                    sizes="(max-width: 768px) 100vw, 400px"
                    loading="lazy"
                  />
                )}
                <div class="p-6">
                  <h3 class="mb-2 text-xl font-bold uppercase">{service.title}</h3>
                  <p class="text-muted">{service.description}</p>
                </div>
              </article>
            </div>
          );
        })
      }
      <Fragment slot="dots">
        {services.map((_, index) => (
          <button
            type="button"
            class:list={['carousel__dot', index === 0 && 'is-active']}
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            aria-label={`Слайд ${index + 1}`}
          />
        ))}
      </Fragment>
    </Carousel>
  </div>
</section>
