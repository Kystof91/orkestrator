---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'СЭР — Сила. Энергия. Результат.',
  description = 'Премиальный фитнес-клуб в Москве. Современное оборудование, профессиональные тренеры, круглосуточный режим работы.',
  ogImage = '/favicon.svg',
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-sm focus:bg-accent focus:px-4 focus:py-2 focus:text-white"
    >
      Перейти к содержимому
    </a>
    <slot />
    <script>
      import { initModals } from '../scripts/modal.ts';
      import { initCarousels } from '../scripts/carousel.ts';
      import { initScrollReveal } from '../scripts/scroll-reveal.ts';
      import { initMobileMenu } from '../scripts/mobile-menu.ts';
      import { initHero } from '../scripts/hero.ts';
      import { initCounters } from '../scripts/counters.ts';

      initModals();
      initCarousels();
      initScrollReveal();
      initMobileMenu();
      initHero();
      initCounters();
    </script>
  </body>
</html>

<style is:global>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
